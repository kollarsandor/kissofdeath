def listAllClose (xs ys : List FixedQ) (absTol : FixedQ) : Bool :=
  List.recOn (motive := fun _ => List FixedQ → Bool) xs
    (fun ys2 =>
      List.recOn (motive := fun _ => Bool) ys2
        Bool.true
        (fun _ _ _ => Bool.false))
    (fun x xt ihx ys2 =>
      List.recOn (motive := fun _ => Bool) ys2
        Bool.false
        (fun y yt _ =>
          bAnd (FixedQ.leB' (FixedQ.absDiff x y) absTol) (ihx yt)))
    ys

